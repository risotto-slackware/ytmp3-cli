#!/usr/bin/env bash

# ytmp3 — download YouTube audio as MP3

set -e

APP_NAME="ytmp3"

check_dependencies() {
    command -v yt-dlp >/dev/null 2>&1 || {
        echo "❌ yt-dlp is not installed."
        echo "Install with:"
        echo "  sudo apt install yt-dlp"
        exit 1
    }

    command -v ffmpeg >/dev/null 2>&1 || {
        echo "❌ ffmpeg is not installed."
        echo "Install with:"
        echo "  sudo apt install ffmpeg"
        exit 1
    }
}

download_mp3() {
    url="$1"

    if [ -z "$url" ]; then
        echo "Usage:"
        echo "  ytmp3 <youtube-link>"
        exit 1
    fi

    echo "⬇ Downloading audio..."

    yt-dlp \
        -x \
        --audio-format mp3 \
        --audio-quality 0 \
        --embed-metadata \
        --embed-thumbnail \
        -o "%(title)s.%(ext)s" \
        "$url"

    echo "Finished!"
}

check_dependencies
download_mp3 "$1"
